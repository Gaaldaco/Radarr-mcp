# URL of your Radarr instance (no trailing slash)
RADARR_URL=http://localhost:7878

# Radarr API key – find it in Radarr → Settings → General → Security
RADARR_API_KEY=your_radarr_api_key_here

# Transport mode: "http" (default, for Railway/remote) or "stdio" (Claude Desktop local)
TRANSPORT=http

# Port the HTTP server listens on (Railway sets this automatically)
PORT=3000
